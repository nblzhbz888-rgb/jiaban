{
  "name": "@jiaban/server-shared",
  "type": "module",
  "version": "0.1.0",
  "description": "Server shared types, utilities for Jiaban server components and runtimes",
  "author": {
    "name": "梁宗靖"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./types": {
      "types": "./dist/types/index.d.mts",
      "default": "./dist/types/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "pnpm run build",
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jiaban/plugin-protocol": "workspace:*"
  }
}
